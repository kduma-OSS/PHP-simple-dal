{
    "name": "kduma/simple-dal-integrity-hash",
    "description": "Simple DAL - PHP hash() integrity implementations",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "Simple-DAL",
        "Simple-DAL-plugin"
    ],
    "homepage": "https://opensource.duma.sh/libraries/php/simple-dal",
    "authors": [
        {
            "name": "kduma",
            "email": "kduma@users.noreply.github.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "kduma/simple-dal-integrity-contracts": "^0.2.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "KDuma\\SimpleDAL\\Integrity\\Hash\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KDuma\\SimpleDAL\\Integrity\\Hash\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.2-dev"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
