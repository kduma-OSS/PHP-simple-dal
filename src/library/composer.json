{
    "name": "kduma/simple-dal",
    "description": "Simple DAL - Core library",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "Simple-DAL"
    ],
    "homepage": "https://opensource.duma.sh/libraries/php/simple-dal",
    "authors": [
        {
            "name": "kduma",
            "email": "kduma@users.noreply.github.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "kduma/simple-dal-contracts": "^0.1",
        "kduma/simple-dal-adapter-contracts": "^0.1"
    },
    "require-dev": {
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "KDuma\\SimpleDAL\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KDuma\\SimpleDAL\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.1-dev"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
