{
    "name": "kduma/simple-dal",
    "description": "Simple DAL - Core library",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "kduma/simple-dal-contracts": "^0.0.1",
        "kduma/simple-dal-adapter-contracts": "^0.0.1"
    },
    "require-dev": {
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "KDuma\\SimpleDAL\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KDuma\\SimpleDAL\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.0.x-dev"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
