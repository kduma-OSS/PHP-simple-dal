{
    "name": "kduma/simple-dal-zip-adapter",
    "description": "Simple DAL - ZIP archive adapter",
    "type": "library",
    "license": "MIT",
    "keywords": ["Simple-DAL", "Simple-DAL-adapter"],
    "homepage": "https://opensource.duma.sh/libraries/php/simple-dal",
    "authors": [
        {
            "name": "kduma",
            "email": "kduma@users.noreply.github.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "kduma/simple-dal-adapter-contracts": "^0.1",
        "kduma/simple-dal-directory-adapter": "^0.1",
        "league/flysystem": "^3.0",
        "league/flysystem-ziparchive": "^3.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "kduma/simple-dal": "^0.1"
    },
    "autoload": {
        "psr-4": {
            "KDuma\\SimpleDAL\\Adapter\\Zip\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KDuma\\SimpleDAL\\Adapter\\Zip\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.1-dev"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
