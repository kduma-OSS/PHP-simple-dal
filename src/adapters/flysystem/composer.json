{
    "name": "kduma/simple-dal-flysystem-adapter",
    "description": "Simple DAL - Flysystem adapter (local, ZIP, S3, etc.)",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "Simple-DAL",
        "Simple-DAL-adapter"
    ],
    "homepage": "https://opensource.duma.sh/libraries/php/simple-dal",
    "authors": [
        {
            "name": "kduma",
            "email": "kduma@users.noreply.github.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "kduma/simple-dal-adapter-contracts": "^0.0.4",
        "league/flysystem": "^3.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "kduma/simple-dal": "^0.0.4"
    },
    "suggest": {
        "league/flysystem-ziparchive": "For ZIP archive storage"
    },
    "autoload": {
        "psr-4": {
            "KDuma\\SimpleDAL\\Adapter\\Flysystem\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KDuma\\SimpleDAL\\Adapter\\Flysystem\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.1-dev"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
