{
    "name": "kduma/simple-dal-contracts",
    "description": "Simple DAL - Contracts and interfaces",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "KDuma\\SimpleDAL\\Contracts\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KDuma\\SimpleDAL\\Contracts\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
