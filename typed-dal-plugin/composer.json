{
    "name": "kduma/simple-dal-typed",
    "description": "Simple DAL - Typed Records plugin with auto-mapping and converters",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "kduma/simple-dal-typed-contracts": "^1.0",
        "kduma/simple-dal-contracts": "^1.0",
        "kduma/simple-dal-adapter-contracts": "^1.0",
        "kduma/simple-dal": "^1.0",
        "spatie/php-attribute-reader": "^1.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "kduma/simple-dal-db-adapter": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "KDuma\\SimpleDAL\\Typed\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KDuma\\SimpleDAL\\Typed\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.0.x-dev"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
